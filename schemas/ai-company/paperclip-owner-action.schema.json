{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaperclipOwnerActionQueueItem",
  "type": "OBJECT",
  "properties": {
    "action_id": { "type": "STRING" },
    "action_type": {
      "type": "STRING",
      "enum": [
        "merge",
        "deploy",
        "publish",
        "spend",
        "customer_comms",
        "permanent_worker",
        "provider_live_api",
        "production_data_mutation"
      ]
    },
    "title": { "type": "STRING" },
    "priority": { "type": "STRING", "enum": ["low", "medium", "high"] },
    "risk_level": { "type": "STRING", "enum": ["low", "medium", "high"] },
    "approval_required": { "type": "BOOLEAN" },
    "recommended_owner_decision": { "type": "STRING" },
    "blocked_until_owner_approval": { "type": "BOOLEAN" },
    "source": { "type": "STRING" },
    "safety_notes": { "type": "STRING" }
  },
  "required": [
    "action_id",
    "action_type",
    "title",
    "priority",
    "risk_level",
    "approval_required",
    "recommended_owner_decision",
    "blocked_until_owner_approval"
  ]
}
